{
  "name": "study-spot-check",
  "version": "1.0.1",
  "description": "研究生错题库高效点检系统",
  "author": "Antigravity",
  "repository": {
    "type": "git",
    "url": "https://github.com/shallow1822/Wrong-Question-Spot-Check-System.git"
  },
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "rebuild": "electron-rebuild",
    "postinstall": "electron-builder install-app-deps"
  },
  "build": {
    "appId": "com.gravity.spotcheck",
    "productName": "StudySpotCheck",
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!dist"
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.education"
    },
    "dmg": {
      "contents": [
        {
          "x": 410,
          "y": 150,
          "type": "link",
          "path": "/Applications"
        },
        {
          "x": 130,
          "y": 150,
          "type": "file"
        }
      ]
    },
    "publish": {
      "provider": "github",
      "owner": "shallow1822",
      "repo": "Wrong-Question-Spot-Check-System"
    },
    "asar": true,
    "asarUnpack": [
      "**/node_modules/better-sqlite3/**/*"
    ]
  },
  "dependencies": {
    "better-sqlite3": "^11.0.0"
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3"
  }
}